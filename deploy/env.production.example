# ── Production environment ──────────────────────────────────────────────
# Copy this file to the project root as `.env` ON THE SERVER and fill it in.
# Generate strong random values with:  openssl rand -hex 32

# Your domain (Caddy gets the HTTPS certificate for it automatically)
DOMAIN=fuel.example.com

# Oracle passwords used by docker-compose.yml
#  - ORACLE_SYS_PASSWORD: the SYSTEM/SYS password inside the DB container
#  - ORACLE_PASSWORD:     the MODBUS_ADMIN app user password
ORACLE_SYS_PASSWORD=CHANGE_ME_strong_password_1
ORACLE_PASSWORD=CHANGE_ME_strong_password_2
ORACLE_USER=MODBUS_ADMIN

# Auth — MUST be a long random secret in production (openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_long_random_secret

# Shared secret for site agents (agent/.env must use the same value)
AGENT_TOKEN=CHANGE_ME_long_random_token

# Allowed browser origins (your site URL)
CORS_ORIGINS=https://fuel.example.com

# Datakom Rainbow cloud
DK_ENABLED=1
DK_VERBOSE=0
DK_USER=your_datakom_user
DK_PASS=your_datakom_password

# Direct-TCP Modbus defaults (used only when no site agent serves a device)
MODBUS_PORT=502
MODBUS_UNIT_ID=1
